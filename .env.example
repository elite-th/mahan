# ═══════════════════════════════════════════════════════
#  NewModernVIRA — Environment Variables Template
#  کپی کنید → .env.local → مقادیر واقعی را جایگزین کنید
# ═══════════════════════════════════════════════════════

# ── ووکامرس (WooCommerce REST API) ─────────────────────
WOOCOMMERCE_CONSUMER_KEY=ck_YOUR_KEY_HERE
WOOCOMMERCE_CONSUMER_SECRET=cs_YOUR_SECRET_HERE
NEXT_PUBLIC_GRAPHQL_URI=https://your-wordpress-domain.com/graphql
NEXT_PUBLIC_WP_API_URL=https://your-wordpress-domain.com/wp-json
NEXT_PUBLIC_API_BASE_URL=https://your-wordpress-domain.com/wp-json/wp/v2

# ── WordPress Application Password (برای ثبت‌نام) ──────
# نام کاربری ادمین وردپرس + رمز اپلیکیشن
# ساخت: وردپرس → کاربران → پروفایل → Application Passwords
WP_APP_USERNAME=admin
WP_APP_PASSWORD=your-application-password-here

# ── زیبال (درگاه پرداخت) ──────────────────────────────
ZIBAL_MERCHANT=YOUR_MERCHANT_ID
ZIBAL_SANDBOX=false

# ── آدرس سایت ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-site-domain.com

# ── hCaptcha (CAPTCHA) ────────────────────────────────
# برای محافظت از فرم ثبت‌نام در برابر ربات‌های spam
# ساخت: https://dashboard.hcaptcha.com → New Site
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key_here
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key_here

# ── Torob API (product feed) ──────────────────────────
# برای همگام‌سازی محصولات با ترب
# روی true تنظیم کنید وقتی JWT ترب فعال شد
TOROB_VERIFY_JWT=false
